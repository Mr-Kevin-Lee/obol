# Copy this file to .env and fill in your own values.
# .env is gitignored — never commit real credentials.
#
# Used only for local development/testing (the #[ignore]'d Plaid Sandbox
# integration tests and examples/plaid_link_spike.rs in crates/core/).
# The shipped app itself stores its Plaid client_id/secret in Keychain,
# not env vars (D20).
#
# client_id is the same across Sandbox/Production; PLAID_SECRET should be
# your Sandbox secret unless you're deliberately running
# plaid_link_spike.rs with PLAID_ENVIRONMENT=production.

PLAID_CLIENT_ID=your_client_id_here
PLAID_SECRET=your_sandbox_secret_here
